@{
    ViewData["Title"] = "Executive Profile";
    Layout = "~/Views/Shared/Layouts/_SampleSamplesLayout.cshtml";
    ViewData["Landing"] = "Samples";
}

@Html.Raw("""
<!--Executive profile figure-->
<figure class="executive-profile">
  <img src="/images/blockquote-with-image.jpg" alt="Image Description" />
