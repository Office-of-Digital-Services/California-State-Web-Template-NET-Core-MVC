      <div class="cagov-header-full__3-main-menu">
        <nav aria-label="Main navigation">
          <ul>
            <li>
              <a href="https://www.ca.gov/services/">Services</a>
            </li>
            <li>
              <a href="https://www.ca.gov/departments/">Departments</a>
            </li>
            <li>
              <a href="https://www.ca.gov/about-california/"
                >About California</a
              >
