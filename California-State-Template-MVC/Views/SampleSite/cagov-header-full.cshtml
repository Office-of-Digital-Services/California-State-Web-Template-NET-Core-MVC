      <!--end cagov-header-full__3-search-->

      <!--main menu-->
      <details
        class="cagov-header-full__3-main-menu-button"
        name="cagov-header-full__buttongroup">
        <summary lang="en">
          <span class="cagov-sr-only">Main menu</span>
          <span
            aria-hidden="true"
            class="cagov-header-full__4-main-menu-hamburger"></span>
