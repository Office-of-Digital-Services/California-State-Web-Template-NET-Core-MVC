@{
    ViewData["Title"] = "Executive Profile Dark";
    Layout = "~/Views/Shared/Layouts/_SampleSamplesLayout.cshtml";
    ViewData["Landing"] = "Samples";
}

@Html.Raw("""
<div class="section-standout">
  <!--Executive profile figure-->
  <figure class="executive-profile bg-transparent dark">
    <img src="/images/blockquote-with-image.jpg" alt="Image Description" />
    <div class="executive-profile-body">
      <p>Official Title</p>
      <h3 class="executive-name">Name</h3>
      <p>Government agency</p>
      <p>
        <a href="javascript:;" aria-label="Link to Official's Website">
          Bio or contact info
        </a>
      </p>
    </div>
  </figure>
  <!-- End Figure -->
</div>
""")