        ("/samples/tabs.html", "Tabs"),
        ("/samples/timeline.html", "Timeline"),
    };

    var currentPath = Context.Request.Path.Value ?? "/";
    if (string.IsNullOrWhiteSpace(currentPath) || currentPath == "/")
    {
        currentPath = "/index.html";
    }

    currentPath = currentPath.TrimEnd('/' );
    if (!currentPath.EndsWith(".html", StringComparison.OrdinalIgnoreCase))
    {
        currentPath += ".html";
    }
}

<nav aria-labelledby="navigation-list" class="side-navigation sticky-6">
  <ul class="list-navigation">
    <li>
      <a href="javascript:;" aria-hidden="true" class="d-none">Samples</a>
    </li>
@foreach (var entry in entries)
{
    var activeClass = string.Equals(currentPath, entry.Url, StringComparison.OrdinalIgnoreCase)
        ? "active"
        : string.Empty;
    <li>
      <a href="@entry.Url" class="@activeClass">@entry.Title</a>
    </li>
}
  </ul>
</nav>